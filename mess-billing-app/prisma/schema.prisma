generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Hostel {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime  @default(now())

  students  Student[]
}

model Course {
  id          Int       @id @default(autoincrement())
  name        String    @unique  // e.g. BTech, MTech, PhD
  createdAt   DateTime  @default(now())

  students    Student[]
}

model Session {
  id          Int       @id @default(autoincrement())
  name        String    @unique  // e.g. 2026-I, 2026-II
  startYear   Int
  semester    String    // "I" or "II"
  createdAt   DateTime  @default(now())

  messAssignments  StudentMessAssignment[]
  monthlyRebates   MonthlyRebate[]
  messRates        MessRate[]
  feesDeposited    FeesDeposited[]
  refunds          Refund[]
}

model Student {
  id             Int      @id @default(autoincrement())
  entryNo        String   @unique
  name           String
  batch          String?
  hostel         String?  // denormalized name, kept for legacy
  email          String?  @unique
  password       String?  // bcrypt-hashed password
  resetToken     String?  // random token for password reset
  resetTokenExp  DateTime? // token expiry time
  address        String?
  messSecurity   Float    @default(0)
  bankAccountNo  String?
  bankName       String?
  ifsc           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  isBankEditable Boolean  @default(true)

  courseId       Int?
  course         Course?  @relation(fields: [courseId], references: [id])

  hostelId       Int?
  hostelRef      Hostel?  @relation(fields: [hostelId], references: [id])

  messAssignments  StudentMessAssignment[]
  monthlyRebates   MonthlyRebate[]
  feesDeposited    FeesDeposited[]
  refunds          Refund[]
}

model Mess {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messAssignments StudentMessAssignment[]
  messRates       MessRate[]
}

model StudentMessAssignment {
  id        Int     @id @default(autoincrement())
  studentId Int
  messId    Int
  sessionId Int

  student   Student @relation(fields: [studentId], references: [id])
  mess      Mess    @relation(fields: [messId], references: [id])
  session   Session @relation(fields: [sessionId], references: [id])

  @@unique([studentId, sessionId])
}

model MonthlyRebate {
  id          Int      @id @default(autoincrement())
  studentId   Int
  sessionId   Int
  month       Int      // 1 to 12
  year        Int
  rebateDays  Int
  createdAt   DateTime @default(now())

  student     Student  @relation(fields: [studentId], references: [id])
  session     Session  @relation(fields: [sessionId], references: [id])

  @@unique([studentId, sessionId, month, year])
}

model MessRate {
  id             Int     @id @default(autoincrement())
  messId         Int
  sessionId      Int
  month          Int     // 1 to 12
  monthlyRate    Float
  gstPercentage  Float   @default(0)

  mess        Mess    @relation(fields: [messId], references: [id])
  session     Session @relation(fields: [sessionId], references: [id])

  @@unique([messId, sessionId, month])
}

model FeesDeposited {
  id          Int      @id @default(autoincrement())
  studentId   Int
  sessionId   Int
  amount      Float
  paymentDate DateTime
  createdAt   DateTime @default(now())

  student     Student  @relation(fields: [studentId], references: [id])
  session     Session  @relation(fields: [sessionId], references: [id])
}

model Refund {
  id          Int      @id @default(autoincrement())
  studentId   Int
  sessionId   Int
  amount      Float
  paymentDate DateTime
  createdAt   DateTime @default(now())

  student     Student  @relation(fields: [studentId], references: [id])
  session     Session  @relation(fields: [sessionId], references: [id])
}
